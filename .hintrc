{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "min-height: auto",
          "border-color: color-mix(in srgb, var(--primary-color) 48%, var(--border))",
          "border: 1px solid color-mix(in srgb, var(--primary-color) 28%, var(--border))"
        ]
      }
    ],
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off",
        "link-name": "off"
      }
    ],
    "axe/forms": [
      "default",
      {
        "select-name": "off"
      }
    ],
    "no-inline-styles": "off",
    "meta-viewport": "off"
  }
}